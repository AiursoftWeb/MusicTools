@using Microsoft.AspNetCore.Mvc.Localization
@using Aiursoft.MusicTools.Services.FileStorage
@model Aiursoft.MusicTools.Models.DashboardViewModels.MelodyExcerptQuizViewModel
@inject IViewLocalizer Localizer
@inject StorageService Storage

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-12">

            <!-- SCREEN 1: START SCREEN -->
            <div id="start-overlay" class="card shadow-lg border-0 mx-auto" style="max-width: 900px; min-height: 600px;">
                <div class="card-body p-4 p-md-5 d-flex flex-column align-items-center justify-content-center text-center">
                    <div class="mb-4">
                        <div class="display-1 text-primary mb-2">🎼</div>
                        <h1 class="display-5 fw-bold mb-3">@Localizer["Melody Excerpt Quiz"]</h1>
                        <p class="text-secondary lead">@Localizer["Choose a question from the bank or upload your own score."]</p>
                    </div>

                    <div class="w-100" style="max-width: 700px;">

                        <!-- Tab Headers -->
                        <ul class="nav nav-pills nav-fill mb-4 bg-light p-1 rounded-pill" id="quizTabs" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active rounded-pill px-4" id="bank-tab" data-bs-toggle="tab" data-bs-target="#bank-pane" type="button" role="tab">
                                    <i class="bi bi-collection-play me-2"></i>@Localizer["Question Bank"]
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link rounded-pill px-4" id="upload-tab" data-bs-toggle="tab" data-bs-target="#upload-pane" type="button" role="tab">
                                    <i class="bi bi-cloud-upload me-2"></i>@Localizer["Upload Score"]
                                </button>
                            </li>
                        </ul>

                        <!-- Tab Content -->
                        <div class="tab-content text-start" id="quizTabsContent">

                            <!-- Tab 1: Question Bank -->
                            <div class="tab-pane fade show active" id="bank-pane" role="tabpanel">
                                <div class="list-group list-group-flush border rounded mb-4" style="max-height: 300px; overflow-y: auto;">
                                    @foreach (var question in Model.AvailableQuestions)
                                    {
                                        <button type="button" class="list-group-item list-group-item-action py-3 question-bank-item"
                                                data-score-url="@Storage.RelativePathToInternetUrl(question.Score.FilePath)"
                                                data-start-measure="@question.StartMeasureIndex"
                                                data-title="@question.Title">
                                            <div class="d-flex w-100 justify-content-between align-items-center">
                                                <h6 class="mb-1 fw-bold">@question.Title</h6>
                                                <small class="text-muted">@question.Score.Name</small>
                                            </div>
                                            <p class="mb-0 small text-secondary">@Localizer["Measures"]: @(question.StartMeasureIndex + 1) - @(question.StartMeasureIndex + 4)</p>
                                        </button>
                                    }
                                    @if (!Model.AvailableQuestions.Any())
                                    {
                                        <div class="p-4 text-center text-muted">
                                            <i class="bi bi-info-circle mb-2 d-block fs-4"></i>
                                            @Localizer["No pre-defined questions available. Please use the upload option."]
                                        </div>
                                    }
                                </div>
                                <button id="btn-start-bank" class="btn btn-primary btn-lg w-100 p-3 fs-5 fw-bold rounded-pill shadow-sm text-uppercase d-none">
                                    @Localizer["Start from Bank"]
                                </button>
                            </div>

                            <!-- Tab 2: Upload Score -->
                            <div class="tab-pane fade" id="upload-pane" role="tabpanel">
                                <div class="mb-4">
                                    <label class="text-uppercase text-secondary fw-bold small mb-2 d-block">@Localizer["Upload Music Score (MXL or XML)"]</label>
                                    <input type="file" id="file-input" accept=".mxl,.xml,.musicxml" class="form-control form-control-lg border-primary">
                                    <div class="form-text mt-2 text-muted">
                                        @Localizer["Please upload a score with at least 4 measures."]
                                    </div>
                                </div>

                                <div class="row g-4 mb-4">
                                    <div class="col-md-6">
                                        <label class="text-uppercase text-secondary fw-bold small mb-2 d-block border-bottom pb-2">@Localizer["Time Signature"]</label>
                                        <div class="d-flex flex-column gap-2">
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="timeSignature" id="ts-24" value="2/4">
                                                <label class="form-check-label" for="ts-24">2/4</label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="timeSignature" id="ts-34" value="3/4">
                                                <label class="form-check-label" for="ts-34">3/4</label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="timeSignature" id="ts-44" value="4/4" checked>
                                                <label class="form-check-label" for="ts-44">4/4</label>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <label class="text-uppercase text-secondary fw-bold small mb-2 d-block border-bottom pb-2">@Localizer["Difficulty"]</label>
                                        <div class="d-flex flex-column gap-2">
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="difficulty" id="diff-easy" value="easy" checked>
                                                <label class="form-check-label" for="diff-easy">@Localizer["Easy (Stepwise)"]</label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="difficulty" id="diff-hard" value="hard">
                                                <label class="form-check-label" for="diff-hard">@Localizer["Hard (Leaps)"]</label>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <button id="btn-start" class="btn btn-primary btn-lg w-100 p-3 fs-5 fw-bold rounded-pill shadow-sm text-uppercase">
                                    @Localizer["Start Quiz"]
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- SCREEN 2: GAME AREA -->
            <div id="game-board" class="d-none w-100">
                <div class="d-flex flex-column align-items-center w-100">

                    <!-- Score Counters -->
                    <div class="w-100 mb-4 d-flex justify-content-between align-items-center" style="max-width: 1000px;">
                        <button id="btn-back" class="btn btn-link text-decoration-none text-secondary">
                            <i class="bi bi-arrow-left"></i> @Localizer["Back"]
                        </button>
                        <div class="d-flex gap-3">
                            <div class="bg-light rounded-pill px-3 py-1 shadow-sm border">
                                <span class="text-success fw-bold">✅ <span id="correct-count">0</span></span>
                            </div>
                            <div class="bg-light rounded-pill px-3 py-1 shadow-sm border">
                                <span class="text-danger fw-bold">❌ <span id="wrong-count">0</span></span>
                            </div>
                        </div>
                    </div>

                    <!-- Controls -->
                    <div class="w-100 mb-5 text-center" style="max-width: 1000px;">
                        <button id="btn-play-melody" class="btn btn-primary btn-lg rounded-pill px-5 py-3 shadow-sm hover-scale">
                            <i class="bi bi-play-fill fs-3"></i> @Localizer["Play Melody"]
                        </button>
                        <p class="text-muted mt-2">@Localizer["Listen carefully and select the matching notation below."]</p>
                    </div>

                    <!-- Options Area -->
                    <div class="w-100" style="max-width: 1000px;">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <div id="option-0" class="option-card border rounded shadow-sm p-3 position-relative" data-index="0">
                                    <span class="badge bg-secondary position-absolute top-0 start-0 m-2">A</span>
                                    <div id="staff-0" class="staff-container"></div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div id="option-1" class="option-card border rounded shadow-sm p-3 position-relative" data-index="1">
                                    <span class="badge bg-secondary position-absolute top-0 start-0 m-2">B</span>
                                    <div id="staff-1" class="staff-container"></div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div id="option-2" class="option-card border rounded shadow-sm p-3 position-relative" data-index="2">
                                    <span class="badge bg-secondary position-absolute top-0 start-0 m-2">C</span>
                                    <div id="staff-2" class="staff-container"></div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div id="option-3" class="option-card border rounded shadow-sm p-3 position-relative" data-index="3">
                                    <span class="badge bg-secondary position-absolute top-0 start-0 m-2">D</span>
                                    <div id="staff-3" class="staff-container"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="mt-5">
                        <button id="btn-next" class="btn btn-outline-primary px-4 d-none">@Localizer["Next Question"]</button>
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>

<div id="loc-data" hidden>
    <span data-key="correct">@Localizer["Correct!"]</span>
    <span data-key="wrong">@Localizer["Wrong! Try again."]</span>
    <span data-key="loading">@Localizer["Loading score..."]</span>
    <span data-key="custom-load-failed">@Localizer["Failed to load the custom score: "]</span>
    <span data-key="too-short">@Localizer["Score must have at least 4 measures."]</span>
    <span data-key="no-score">@Localizer["Please upload a music score before starting."]</span>
</div>

@section scripts {
    <script type="module" src="~/dist/scripts/melodyExcerptQuiz.js" asp-append-version="true"></script>
    <script>
        window.addEventListener('load', () => {
            if (window.startMelodyExcerptQuiz) {
                window.startMelodyExcerptQuiz();
            }
        });
    </script>
}

@section styles {
    <link rel="stylesheet" href="~/styles/site.css" asp-append-version="true" />
    <style>
        .hover-scale { transition: transform 0.2s; }
        .hover-scale:hover { transform: scale(1.02); }

        .option-card {
            cursor: pointer;
            transition: all 0.2s ease-in-out;
            background: white;
            min-height: 180px;
        }
        .option-card:hover {
            border-color: #0d6efd !important;
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(0,0,0,0.1) !important;
        }
        .option-card.correct {
            border-color: #198754 !important;
            background-color: #f8fff9;
            pointer-events: none;
        }
        .option-card.wrong {
            border-color: #dc3545 !important;
            background-color: #fff8f8;
            opacity: 0.7;
        }

        .staff-container {
            width: 100%;
            overflow-x: auto;
            overflow-y: hidden;
        }

        .question-bank-item.active {
            border-left: 5px solid #0d6efd;
            background-color: #f8fbff;
        }
    </style>
}
