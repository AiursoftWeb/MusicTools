@inject IViewLocalizer Localizer
@model Aiursoft.MusicTools.Models.DashboardViewModels.ChordCalculatorViewModel

@{
    ViewData["Title"] = Localizer["Chord Calculator"];
}

<div id="loc-data" hidden>
    <span data-key="tonic">@Localizer["Tonic"]</span>
    <span data-key="diatonic-chords">@Localizer["Diatonic Chords"]</span>
    <span data-key="major-triad">@Localizer["Major Triad"]</span>
    <span data-key="minor-triad">@Localizer["Minor Triad"]</span>
    <span data-key="diminished-triad">@Localizer["Diminished Triad"]</span>
    <span data-key="augmented-triad">@Localizer["Augmented Triad"]</span>
    <span data-key="invalid-chord">@Localizer["Invalid Chord"]</span>
</div>

<div class="container-fluid py-4">
    <div class="row g-4 justify-content-center">
        <!-- Left Column: Controls -->
        <div class="col-lg-5">
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="card-title mb-0">@Localizer["Circle of Fifths"]</h5>
                </div>
                <div class="card-body text-center">
                    <div class="circle-container mx-auto my-2">
                        <div id="fifths-outer-circle" class="outer-circle"></div>
                        <div id="fifths-inner-circle" class="inner-circle">
                            <div class="current-key-display">
                                <span class="key-name">C</span>
                                <span class="key-mode">Major</span>
                            </div>
                        </div>
                    </div>
                    <div class="controls mt-3">
                        <button id="fifths-rotate-left" class="btn btn-primary">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                 stroke-linejoin="round"
                                 class="lucide lucide-rotate-ccw lucide-sm me-1 align-middle">
                                <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
                                <path d="M3 3v5h5"></path>
                            </svg>
                            @Localizer["Rotate Left"]
                        </button>
                        <button id="fifths-rotate-right" class="btn btn-primary">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                 stroke-linejoin="round"
                                 class="lucide lucide-rotate-cw lucide-sm me-1 align-middle">
                                <path d="M21 12a9 9 0 1 1-9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"></path>
                                <path d="M21 3v5h-5"></path>
                            </svg>
                            @Localizer["Rotate Right"]
                        </button>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">@Localizer["Chord Selection"]</h5>
                </div>
                <div class="card-body">
                    <h6 class="card-subtitle mb-3 text-muted">@Localizer["Mode Selector"]</h6>
                    <div class="row row-cols-1 row-cols-md-2 g-2 mb-4" id="mode-selector">
                        <div class="col">
                            <button class="btn btn-outline-primary w-100 py-2 mode-btn active" data-mode="diatonic">@Localizer["Diatonic Chords"]</button>
                        </div>
                        <div class="col">
                            <button class="btn btn-outline-primary w-100 py-2 mode-btn" data-mode="major">@Localizer["Major Triad"]</button>
                        </div>
                        <div class="col">
                            <button class="btn btn-outline-primary w-100 py-2 mode-btn" data-mode="minor">@Localizer["Minor Triad"]</button>
                        </div>
                        <div class="col">
                            <button class="btn btn-outline-primary w-100 py-2 mode-btn" data-mode="diminished">@Localizer["Diminished Triad"]</button>
                        </div>
                        <div class="col">
                            <button class="btn btn-outline-primary w-100 py-2 mode-btn" data-mode="augmented">@Localizer["Augmented Triad"]</button>
                        </div>
                    </div>

                    <h6 class="card-subtitle mb-3 text-muted">@Localizer["Degree Selector"]</h6>
                    <div class="d-flex flex-wrap gap-2 justify-content-center" id="degree-selector">
                        <button class="btn btn-outline-secondary px-3 degree-btn active" data-degree="1">I</button>
                        <button class="btn btn-outline-secondary px-3 degree-btn" data-degree="2">II</button>
                        <button class="btn btn-outline-secondary px-3 degree-btn" data-degree="3">III</button>
                        <button class="btn btn-outline-secondary px-3 degree-btn" data-degree="4">IV</button>
                        <button class="btn btn-outline-secondary px-3 degree-btn" data-degree="5">V</button>
                        <button class="btn btn-outline-secondary px-3 degree-btn" data-degree="6">VI</button>
                        <button class="btn btn-outline-secondary px-3 degree-btn" data-degree="7">VII</button>
                    </div>
                </div>
                <div class="card-footer text-center bg-light">
                     <div class="h4 fw-bold text-primary mb-0" id="chord-result-display">C Major</div>
                </div>
            </div>
        </div>

        <!-- Right Column: Keyboard -->
        <div class="col-lg-7">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="card-title mb-0">@Localizer["Interactive Piano"]</h5>
                    <button class="btn btn-sm btn-outline-secondary" id="reset-piano-btn">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-refresh-cw lucide-sm me-1 align-middle">
                            <path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
                            <path d="M3 3v5h5"></path>
                            <path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"></path>
                            <path d="M16 16h5v5"></path>
                        </svg>
                        @Localizer["Reset Selection"]
                    </button>
                </div>
                <div class="card-body d-flex flex-column">
                    <div class="piano-container table-responsive mb-4">
                    </div>
                    
                    <div class="mt-auto">
                        <h6>@Localizer["Detected Chord Info"]</h6>
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="p-3 border rounded bg-light">
                                    <div class="small text-muted">@Localizer["Notes"]</div>
                                    <div class="h5 mb-0" id="detected-notes">--</div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="p-3 border rounded bg-light">
                                    <div class="small text-muted">@Localizer["Chord Type"]</div>
                                    <div class="h5 mb-0" id="detected-type">--</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script type="module" src="~/dist/scripts/chordCalculator.js" asp-append-version="true"></script>
}

@section styles {
    <link rel="stylesheet" href="~/styles/site.css" asp-append-version="true"/>
}
