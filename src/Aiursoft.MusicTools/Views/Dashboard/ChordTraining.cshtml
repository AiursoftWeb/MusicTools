@{
    ViewData["Title"] = @Localizer["Chord Training"];
}

<div id="loc-data" hidden>
    <span data-key="correct">@Localizer["Correct!"]</span>
    <span data-key="wrong">@Localizer["Wrong."]</span>
    <span data-key="give-up">@Localizer["I give up"]</span>
    <span data-key="next-question">@Localizer["Next Question"]</span>
    <span data-key="play-chord">@Localizer["Play Chord"]</span>
    <span data-key="question-template">@Localizer["What is the type of the chord played?"]</span>
    <span data-key="chord-major">@Localizer["Major Triad"]</span>
    <span data-key="chord-minor">@Localizer["Minor Triad"]</span>
    <span data-key="chord-diminished">@Localizer["Diminished Triad"]</span>
    <span data-key="chord-augmented">@Localizer["Augmented Triad"]</span>
    <span data-key="root-position">@Localizer["Root Position"]</span>
    <span data-key="first-inversion">@Localizer["First Inversion"]</span>
    <span data-key="second-inversion">@Localizer["Second Inversion"]</span>
</div>

<div class="container-fluid py-4 position-relative">
    <!-- Score Counters -->
    <div class="position-absolute top-0 end-0 mt-3 me-3 d-flex gap-3">
        <div class="bg-light rounded-pill px-3 py-2 shadow-sm d-flex align-items-center gap-2 border" title="@Localizer["Correct"]">
            <span class="fs-4">✅</span>
            <span id="correct-count" class="fs-4 fw-bold text-success">0</span>
        </div>
        <div class="bg-light rounded-pill px-3 py-2 shadow-sm d-flex align-items-center gap-2 border" title="@Localizer["Wrong"]">
            <span class="fs-4">❌</span>
            <span id="wrong-count" class="fs-4 fw-bold text-danger">0</span>
        </div>
    </div>

    <div class="row g-4 justify-content-center mb-4">
        <div class="col-lg-8 text-center">
            <h1 class="display-5 mb-4">@Localizer["Chord Training"]</h1>
            <p id="question-label" class="lead">@Localizer["Listen to the chord and identify its type."]</p>
        </div>
    </div>

    <div class="row g-4 justify-content-center mb-5">
        <div class="col-lg-8 d-flex flex-column justify-content-center align-items-center gap-4">
            <div class="d-flex flex-wrap gap-4 justify-content-center">
                <div class="btn-group shadow-sm" role="group" aria-label="Start mode">
                    <input type="radio" class="btn-check" name="start-mode" id="mode-random" value="random" checked autocomplete="off">
                    <label class="btn btn-outline-primary px-3 py-2" for="mode-random">
                        <i class="bi bi-shuffle me-1"></i> @Localizer["Random Root"]
                    </label>

                    <input type="radio" class="btn-check" name="start-mode" id="mode-fixed-c" value="fixed-c" autocomplete="off">
                    <label class="btn btn-outline-primary px-3 py-2" for="mode-fixed-c">
                        <i class="bi bi-type-bold me-1"></i> @Localizer["Root as C"]
                    </label>
                </div>
                
                <div class="btn-group shadow-sm" role="group" aria-label="Play mode">
                    <input type="radio" class="btn-check" name="play-mode" id="mode-block" value="block" checked autocomplete="off">
                    <label class="btn btn-outline-primary px-3 py-2" for="mode-block">
                        <i class="bi bi-music-note-list me-1"></i> @Localizer["Block Chord"]
                    </label>

                    <input type="radio" class="btn-check" name="play-mode" id="mode-arpeggio" value="arpeggio" autocomplete="off">
                    <label class="btn btn-outline-primary px-3 py-2" for="mode-arpeggio">
                        <i class="bi bi-music-note-beamed me-1"></i> @Localizer["Arpeggio"]
                    </label>
                </div>

                <div class="btn-group shadow-sm" role="group" aria-label="Scale mode">
                    <input type="radio" class="btn-check" name="scale-mode" id="scale-c-major" value="c-major" checked autocomplete="off">
                    <label class="btn btn-outline-primary px-3 py-2" for="scale-c-major">
                        <i class="bi bi-circle me-1"></i> @Localizer["C Major (White Keys)"]
                    </label>

                    <input type="radio" class="btn-check" name="scale-mode" id="scale-random" value="random" autocomplete="off">
                    <label class="btn btn-outline-primary px-3 py-2" for="scale-random">
                        <i class="bi bi-palette me-1"></i> @Localizer["Random Scale"]
                    </label>
                </div>

                <div class="btn-group shadow-sm" role="group" aria-label="Voicing mode">
                    <input type="radio" class="btn-check" name="voicing-mode" id="voicing-root" value="root" checked autocomplete="off">
                    <label class="btn btn-outline-primary px-3 py-2" for="voicing-root">
                        <i class="bi bi-arrow-down-circle me-1"></i> @Localizer["Root position (Root is lowest)"]
                    </label>

                    <input type="radio" class="btn-check" name="voicing-mode" id="voicing-random" value="random" autocomplete="off">
                    <label class="btn btn-outline-primary px-3 py-2" for="voicing-random">
                        <i class="bi bi-layers me-1"></i> @Localizer["Random Inversion"]
                    </label>
                </div>
            </div>

            <button id="play-button" class="btn btn-primary btn-lg rounded-pill px-5 py-3 shadow hover-scale d-flex align-items-center gap-2">
                <i class="bi bi-play-fill fs-3"></i>
                <span id="play-button-text" class="fs-4 fw-bold">@Localizer["Play Chord"]</span>
            </button>
        </div>
    </div>

    <div id="chord-options-row" class="row g-4 justify-content-center d-none">
        <div class="col-lg-10">
            <div id="chord-options" class="row row-cols-2 row-cols-md-3 row-cols-lg-5 g-3 justify-content-center">
                <!-- Chords will be injected here -->
            </div>
        </div>
    </div>

    <div id="result-details" class="row g-4 justify-content-center mt-5 d-none">
        <div class="col-lg-4">
            <div class="card h-100 shadow-sm border-0 bg-light">
                <div class="card-body text-center d-flex flex-column justify-content-center">
                    <h6 class="text-muted text-uppercase small mb-2">@Localizer["Correct Answer"]</h6>
                    <h2 id="result-chord-name" class="display-6 fw-bold text-primary mb-2"></h2>
                    <p id="result-inversion" class="lead text-info fw-bold mb-0"></p>
                </div>
            </div>
        </div>
        <div class="col-lg-8">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body">
                    <div id="piano-container" class="piano-container table-responsive"></div>
                </div>
            </div>
        </div>
    </div>
</div>

@* ReSharper disable once Razor.SectionNotResolved *@

@section scripts {
    <script type="module" src="~/dist/scripts/chordTraining.js" asp-append-version="true"></script>
    <script>
        window.addEventListener('load', () => {
             window.startChordTraining('piano-container');
        });
    </script>
}

@* ReSharper disable once Razor.SectionNotResolved *@

@section styles {
    <link rel="stylesheet" href="~/styles/site.css" asp-append-version="true"></link>

    <style>
        .hover-scale {
            transition: transform 0.2s;
        }
        .hover-scale:hover {
            transform: scale(1.05);
        }
        .chord-btn {
            font-size: 1.1rem;
            font-weight: 500;
            transition: all 0.2s ease-in-out;
        }
    </style>
}
