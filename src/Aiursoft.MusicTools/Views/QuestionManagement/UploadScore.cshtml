@model Aiursoft.MusicTools.Models.QuestionManagementViewModels.UploadScoreViewModel

<div class="row mb-2 mb-xl-3">
    <div class="col-auto d-none d-sm-block">
        <h3>@Localizer["Upload New Score"]</h3>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <form asp-action="UploadScore" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label">@Localizer["Score Name"]</label>
                <input asp-for="Name" class="form-control" placeholder="@Localizer["e.g. Mozart Sonata No. 16"]" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">@Localizer["MusicXML or MXL File"]</label>
                <vc:file-upload
                    asp-for="ScorePath"
                    subfolder="score"
                    allowed-extensions="mxl xml musicxml"
                    max-size-in-mb="20">
                </vc:file-upload>
                <span asp-validation-for="ScorePath" class="text-danger"></span>
            </div>

            <div class="mt-4">
                <button type="submit" class="btn btn-primary">@Localizer["Upload and Save"]</button>
                <a asp-action="Index" class="btn btn-link">@Localizer["Cancel"]</a>
            </div>
        </form>
    </div>
</div>

@* ReSharper disable once Razor.SectionNotResolved *@
@section styles {
    <link rel="stylesheet" href="~/node_modules/dropify/dist/css/dropify.min.css" />
    <link rel="stylesheet" href="~/styles/uploader.css" />
}

@* ReSharper disable once Razor.SectionNotResolved *@
@section scripts {
    <script src="~/node_modules/dropify/dist/js/dropify.min.js"></script>
}
